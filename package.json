{
  "name": "@sentinels/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Sentinel Labs trust infrastructure",
  "license": "Apache-2.0",
  "author": "Sentinel Labs <hello@sentinels.today>",
  "homepage": "https://sentinels.today",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sentinels-Today/sentinel-sdk.git"
  },
  "bugs": "https://github.com/Sentinels-Today/sentinel-sdk/issues",
  "keywords": [
    "sentinel",
    "robots",
    "trust",
    "identity",
    "attestation",
    "ed25519",
    "did"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
